    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.1",
    "vitest": "^4.1.1"
