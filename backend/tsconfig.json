{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "types": ["node"]
    },
    "include": [
        "src/**/*.ts",
        "scripts/**/*.ts",
        "sst.config.ts",
        ".sst/platform/config.d.ts",
        "sst-env.d.ts"
    ]
}