# Copy file này thành .env và điền giá trị từ: npx sst dev (xem output)
# Chỉ dùng cho scripts local (seed-admin.ts, v.v.)
# Lambda functions dùng SST Resource tự động, không cần file này

# Lấy từ output của sst dev hoặc sst deploy
USER_POOL_ID=ap-southeast-1_xxxxxxxxx
USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
TABLE_NAME=Spotify-MainTable
BUCKET_NAME=spotify-backend-xxx-spotifymediabucket-xxx
AWS_REGION=ap-southeast-1

# App config (optional - có giá trị mặc định trong src/shared/config.ts)
# DEFAULT_PAGE_SIZE=20
# MAX_PAGE_SIZE=100
# UPLOAD_URL_EXPIRES_IN=300
# SEARCH_MAX_RESULTS=50
# MAX_FILE_SIZE_MB=50
