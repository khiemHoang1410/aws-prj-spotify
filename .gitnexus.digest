@import url("https://fonts.cdnfonts.com/css/ica-rubrik-black");
@import url("https://fonts.cdnfonts.com/css/poppins");

:root {
  --color-primary: #c5e054;
  --color-primary-dark: #a8c93a;
  --color-background: #000000;
  --color-text: #ffffff;
  --color-text-secondary: #aaaaaa;
  --border-radius: 12px;
  --border-radius-full: 9999px;
}

body {
  font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans",
    "Helvetica Neue", sans-serif;
  background-color: var(--color-background);
  color: var(--color-text);
  line-height: 1.5;
}

img {
  max-width: 100%;
  height: auto;
}

.container {
  width: 100%;
  max-width: 1500px;
  margin: 0 auto;
  padding: 0 1rem;
}

/* Button styles */
button {
  position: relative;
  display: inline-block;
  cursor: pointer;
  outline: none;
  border: 0;
  vertical-align: middle;
  text-decoration: none;
  background: transparent;
  padding: 0;
  font-size: inherit;
  font-family: inherit;
 }
 
 button.learn-more {
  width: 12rem;
  height: auto;
 }
 
 button.learn-more .circle {
  transition: all 0.45s cubic-bezier(0.65, 0, 0.076, 1);
  position: relative;
  display: block;
  margin: 0;
  width: 3rem;
  height: 3rem;
  background: #a8c93a;
  border-radius: 1.625rem;
 }
 
 button.learn-more .circle .icon {
  transition: all 0.45s cubic-bezier(0.65, 0, 0.076, 1);
  position: absolute;
  top: 0;
  bottom: 0;
  margin: auto;
  background: #fff;
 }
 
 button.learn-more .circle .icon.arrow {
  transition: all 0.45s cubic-bezier(0.65, 0, 0.076, 1);
  left: 0.625rem;
  width: 1.125rem;
  height: 0.125rem;
  background: none;
 }
 
 button.learn-more .circle .icon.arrow::before {
  position: absolute;
  content: "";
  top: -0.29rem;
  right: 0.0625rem;
  width: 0.625rem;
  height: 0.625rem;
  border-top: 0.125rem solid #fff;
  border-right: 0.125rem solid #fff;
  transform: rotate(45deg);
 }
 
 button.learn-more .button-text {
  transition: all 0.45s cubic-bezier(0.65, 0, 0.076, 1);
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 0.75rem 0;
  margin: 0 0 0 1.85rem;
  color: #282936;
  font-weight: 700;
  line-height: 1.6;
  text-align: center;
  text-transform: uppercase;
 }
 
 button:hover .circle {
  width: 100%;
 }
 
 button:hover .circle .icon.arrow {
  background: #fff;
  transform: translate(1rem, 0);
 }
 
 button:hover .button-text {
  color: #fff;
 }

 /**/
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.75rem 1.5rem;
  border: none;
  border-radius: var(--border-radius-full);
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}

.btn-link {
  background: transparent;
  color: var(--color-text); 
  padding: 0.5rem;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 14px;
  font-family: inherit;
  font-weight: 800;
  text-transform: uppercase;
  position: relative;
  border: none;
  background: none;
  transition-timing-function: cubic-bezier(0.25, 0.8, 0.25, 1);
  transition-duration: 400ms;
  transition-property: color;
}

/* Hover and focus states */
.btn-link:focus,
.btn-link:hover {
  color: #fff; /* Uiverse.io hover/focus color */
}

.btn-link:after {
  content: "";
  pointer-events: none;
  bottom: -2px;
  left: 50%;
  position: absolute;
  width: 0%;
  height: 2px;
  background-color: #fff;
  transition-timing-function: cubic-bezier(0.25, 0.8, 0.25, 1);
  transition-duration: 400ms;
  transition-property: width, left;
}

.btn-link:focus:after,
.btn-link:hover:after {
  width: 100%;
  left: 0%;
}

/**/
.animated-button {
  position: relative;
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 16px 36px;
  border: 4px solid;
  border-color: transparent;
  font-size: 16px;
  background-color: inherit;
  border-radius: 100px;
  font-weight: 600;
  color: greenyellow;
  box-shadow: 0 0 0 2px greenyellow;
  cursor: pointer;
  overflow: hidden;
  transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
}

.animated-button svg {
  position: absolute;
  width: 24px;
  fill: greenyellow;
  z-index: 9;
  transition: all 0.8s cubic-bezier(0.23, 1, 0.32, 1);
}

.animated-button .arr-1 {
  right: 16px;
}

.animated-button .arr-2 {
  left: -25%;
}

.animated-button .circle {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20px;
  height: 20px;
  background-color: greenyellow;
  border-radius: 50%;
  opacity: 0;
  transition: all 0.8s cubic-bezier(0.23, 1, 0.32, 1);
}

.animated-button .text {
  position: relative;
  z-index: 1;
  transform: translateX(-12px);
  transition: all 0.8s cubic-bezier(0.23, 1, 0.32, 1);
}

.animated-button:hover {
  box-shadow: 0 0 0 12px transparent;
  color: #212121;
  border-radius: 12px;
}

.animated-button:hover .arr-1 {
  right: -25%;
}

.animated-button:hover .arr-2 {
  left: 16px;
}

.animated-button:hover .text {
  transform: translateX(12px);
}

.animated-button:hover svg {
  fill: #212121;
}

.animated-button:active {
  scale: 0.95;
  box-shadow: 0 0 0 4px greenyellow;
}

.animated-button:hover .circle {
  width: 220px;
  height: 220px;
  opacity: 1;
}


/* Header styles */
.header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background: rgba(37, 40, 59, 0.9); 
  backdrop-filter: blur(12px); 
  z-index: 1000;
  padding: 1.2rem 0; 
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3); 
}

.header-container {
  width: 90%;
  max-width: 1400px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* Logo styles */
.logo {
  display: flex;
  align-items: center;
  
}

.logo-image {
  height: 40px; 
  width: auto;
  transition: transform 0.3s ease; 

}

.logo-image:hover {
  transform: scale(1.05); 
}


.nav-menu ul {
  display: flex;
  list-style: none;
  gap: 2.5rem;
  margin: 0;
  padding: 0;
}

.nav-menu a {
  font-family: "Poppins", sans-serif;
  color: var(--color-text, #ffffff);
  text-decoration: none;
  font-size: 1.1rem; 
  font-weight: 500;
  text-transform: uppercase;
  position: relative;
  transition: color 0.3s ease;
}


.nav-menu a:hover,
.nav-menu a.active {
  color: var(--color-primary, #c5e054);
}

.nav-menu a::after {
  content: "";
  position: absolute;
  bottom: -5px;
  left: 50%;
  width: 0%;
  height: 2px;
  background-color: var(--color-primary, #c5e054);
  transition: width 0.4s cubic-bezier(0.25, 0.8, 0.25, 1), left 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.nav-menu a:hover::after,
.nav-menu a.active::after {
  width: 100%;
  left: 0%;
}

.mobile-menu-button {
  display: none;
  background: none;
  border: none;
  color: var(--color-text, #ffffff);
  cursor: pointer;
  transition: color 0.3s ease;
}

.mobile-menu-button:hover {
  color: var(--color-primary, #c5e054);
}

/* Responsive styles */
@media screen and (max-width: 768px) {
  .mobile-menu-button {
    display: block;
    z-index: 1001;
  }

  .nav-menu {
    position: fixed;
    top: 0;
    right: -100%;
    width: 80%;
    height: 100vh;
    background: rgba(37, 40, 59, 0.98); 
    backdrop-filter: blur(12px);
    transition: right 0.4s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: -5px 0 15px rgba(0, 0, 0, 0.5); 
  }

  .nav-menu.active {
    right: 0;
  }

  .nav-menu ul {
    flex-direction: column;
    align-items: center;
    gap: 3rem; 
    padding: 0;
  }

  .nav-menu a {
    font-size: 1.5rem; 
    padding: 0.5rem 0;
  }

  .logo-image {
    height: 35px;
  }
}

@media screen and (max-width: 480px) {
  .nav-menu a {
    font-size: 1.3rem;
  }

  .logo-image {
    height: 30px; 
  }
}

/* Hero section */
.hero-section {
  position: relative;
  height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.7);
  z-index: 1;
}

.hero-image {
  position: absolute;
  right: 0;
  top: 50px;
  height: 100%;
  width: 40%;
  background-image: url(http://localhost:8000/static/images/intropage/hero.png);
  background-size: cover;
  background-position: center;
}



.blur-circle {
  position: absolute;
  border-radius: 50%;
  background-color: rgba(197, 224, 84, 0.3);
  filter: blur(30px);
}

.blur-circle-1 {
  right: 5rem;
  top: 10rem;
  height: 8rem;
  width: 8rem;
}

.blur-circle-2 {
  right: 15rem;
  top: 20rem;
  height: 6rem;
  width: 6rem;
}

.hero-content {
  position: relative;
  z-index: 2;
  padding-top: 10rem;
}

.hero-title {
  font-size: 3.5rem;
  font-weight: 700;
  margin-bottom: 1rem;
}

.hero-description {
  max-width: 25rem;
  margin-bottom: 2rem;
  color: var(--color-text-secondary);
}

.hero-buttons {
  display: flex;
  gap: 1.5rem;
  align-items: center;
}

/* Stats section */
.stats-section {
  padding: 12rem 0;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 2rem;
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 0.875rem;
  color: var(--color-text-secondary);
}

.stat-value {
  font-size: 2.5rem;
  font-weight: 700;
}

.avatar-group {
  display: flex;
  margin-top: 0.5rem;
}

.avatar {
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 50%;
  border: 2px solid var(--color-background);
  overflow: hidden;
  margin-left: -0.5rem;
}

.avatar:first-child {
  margin-left: 0;
}

.avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Trending section */
.trending-section {
  padding: 10rem 0;
}

.trending-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 2rem;
}

.nft-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  width: 100%;
  max-width: 600px;
}

.nft-item {
  aspect-ratio: 1 / 1;
  border-radius: 1.5rem;
  overflow: hidden;
  background-color: #222;
}

.nft-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.trending-content {
  flex: 1;
  min-width: 300px;
}

.trending-label {
  font-size: 0.875rem;
  color: var(--color-primary);
}

.trending-title {
  font-size: 2.5rem;
  font-weight: 700;
  margin: 0.5rem 0 1rem;
}

.trending-description {
  color: var(--color-text-secondary);
  margin-bottom: 2rem;
}


/* top-artists section */
.top-artists-section {
  padding: 2rem 0;
}

.top-artists-header {
  margin-bottom: 2rem;
}

.section-label {
  font-size: 0.875rem;
  color: var(--color-text-secondary);
}

.section-title {
  font-size: 2.5rem;
  font-weight: 700;
  margin: 0.5rem 0 1rem;
}

.section-description {
  color: var(--color-text-secondary);
  max-width: 25rem;
}

.top-artists-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5rem;
}

.top-artist-card {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.top-artist-info1 {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.top-artist-avatar {
  width: 4rem;
  height: 4rem;
  border-radius: 50%;
  overflow: hidden;
}

.top-artist-name {
  font-weight: 600;
}

.top-artist-followers {
  font-size: 0.875rem;
  color: var(--color-text-secondary);
}

.top-artist-artwork {
  display: flex;
  width: 20rem;
  height: 12rem;
  border-radius: 1.5rem;
  overflow: hidden;
  position: relative;
}

.gradient-pink-purple {
  background: linear-gradient(to right, #f472b6, #8b5cf6);
}

.gradient-purple-indigo {
  background: linear-gradient(to right, #8b5cf6, #6366f1);
}

.top-artist-artwork img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.8;
}

/* Partners section */
.partners-section {
  padding: 4rem 0;
}

.partners-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 2rem;
  align-items: center;
}

.partner-logo {
  height: 2rem;
  opacity: 0.7;
  filter: grayscale(1);
  transition: all 0.3s ease;
}

.partner-logo:hover {
  opacity: 1;
  filter: grayscale(0);
}

.partner-logo img {
  height: 100%;
  width: auto;
}

/* Subscribe section */
.subscribe-section {
  padding: 6rem 0;
}

.subscribe-content {
  max-width: 40rem;
}

.subscribe-title {
  font-size: 3rem;
  font-weight: 700;
  margin-bottom: 2rem;
  line-height: 1.2;
}

.btnsub {
  position: relative;
  padding: 10px 20px;
  border-radius: 7px;
  border: 1px solid rgb(126, 181, 42);
  font-size: 14px;
  text-transform: uppercase;
  font-weight: 600;
  letter-spacing: 2px;
  background: transparent;
  color: #fff;
  overflow: hidden;
  box-shadow: 0 0 0 0 transparent;
  -webkit-transition: all 0.2s ease-in;
  -moz-transition: all 0.2s ease-in;
  transition: all 0.2s ease-in;
}

.btnsub:hover {
  background: rgb(126, 181, 42);
  box-shadow: 0 0 30px 5px rgba(126, 181, 42, 0.815);
  -webkit-transition: all 0.2s ease-out;
  -moz-transition: all 0.2s ease-out;
  transition: all 0.2s ease-out;
}

.btnsub:hover::before {
  -webkit-animation: sh02 0.5s 0s linear;
  -moz-animation: sh02 0.5s 0s linear;
  animation: sh02 0.5s 0s linear;
}

.btnsub::before {
  content: '';
  display: block;
  width: 0px;
  height: 86%;
  position: absolute;
  top: 7%;
  left: 0%;
  opacity: 0;
  background: #fff;
  box-shadow: 0 0 50px 30px #fff;
  -webkit-transform: skewX(-20deg);
  -moz-transform: skewX(-20deg);
  -ms-transform: skewX(-20deg);
  -o-transform: skewX(-20deg);
  transform: skewX(-20deg);
}

@keyframes sh02 {
  from {
    opacity: 0;
    left: 0%;
  }

  50% {
    opacity: 1;
  }

  to {
    opacity: 0;
    left: 100%;
  }
}

.btnsub:active {
  box-shadow: 0 0 0 0 transparent;
  -webkit-transition: box-shadow 0.2s ease-in;
  -moz-transition: box-shadow 0.2s ease-in;
  transition: box-shadow 0.2s ease-in;
}

/* Banner section */

.banner {
  width: 100%;
  height: 100vh;
  text-align: center;
  overflow: hidden;
  position: relative;
}

.banner .slider {
  position: absolute;
  width: 200px;
  height: 250px;
  top: 10%;
  left: calc(50% - 100px);
  transform-style: preserve-3d;
  transform: perspective(1000px);
  animation: autoRun 20s linear infinite;
  z-index: 2;
}


@keyframes autoRun {
  from {
    transform: perspective(1000px) rotateX(-16deg) rotateY(0deg);
  }
  to {
    transform: perspective(1000px) rotateX(-16deg) rotateY(360deg);
  }
}

.banner .slider .item {
  position: absolute;
  inset: 0 0 0 0;
  transform: rotateY(calc((var(--position) - 1) * (360 / var(--quantity)) * 1deg)) translateZ(550px);
}

.banner .slider .item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.banner .content {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: min(1400px, 100vw);
  height: max-content;
  padding-bottom: 100px;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  z-index: 1;
}

.banner .content h1 {
  font-family: "ICA Rubrik", sans-serif;
  font-size: 16em;
  line-height: 1em;
  color: greenyellow;
  position: relative;
}

.banner .content h1::after {
  position: absolute;
  inset: 0 0 0 0;
  content: attr(data-content);
  z-index: 2;
  -webkit-text-stroke: 2px #d2d2d2;
  color: transparent;
}

.banner .content .author {
  font-family: "Poppins", sans-serif;
  text-align: right;
  max-width: 200px;
}

.banner .content h2 {
  font-size: 2em;
}

.banner .content .model {
  background-image: url("http://localhost:8000/static/images/intropage/model.jpg");
  width: 100%;
  height: 75vh;
  position: absolute;
  bottom: 0;
  left: 0;
  background-size: auto 100%;
  background-repeat: no-repeat;
  background-position: top center;
  z-index: 1;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-size: 2rem;
  color: #25283b;
}

@media screen and (max-width: 1023px) {
  .banner .slider {
    width: 160px;
    height: 200px;
    left: calc(50% - 80px);
  }
  .banner .slider .item {
    transform: rotateY(calc((var(--position) - 1) * (360 / var(--quantity)) * 1deg)) translateZ(300px);
  }
  .banner .content h1 {
    text-align: center;
    width: 100%;
    text-shadow: 0 10px 20px #000;
    font-size: 7em;
  }
  .banner .content .author {
    color: #fff;
    padding: 20px;
    text-shadow: 0 10px 20px #000;
    z-index: 2;
    max-width: unset;
    width: 100%;
    text-align: center;
    padding: 0 30px;
  }
}

@media screen and (max-width: 767px) {
  .banner .slider {
    width: 100px;
    height: 150px;
    left: calc(50% - 50px);
  }
  .banner .slider .item {
    transform: rotateY(calc((var(--position) - 1) * (360 / var(--quantity)) * 1deg)) translateZ(180px);
  }
  .banner .content h1 {
    font-size: 5em;
  }
}

/* Banner.css */
.container.banner {
  position: relative;
  width: 100%;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.slider {
  position: relative;
  width: 600px;
  height: 600px;
  animation: rotate 30s linear infinite;
}

.slider.paused {
  animation-play-state: paused;
}

.item {
  position: absolute;
  width: 190px;
  height: 254px;
  transform: translate(-50%, -50%)
    rotate(calc(360deg / var(--quantity) * (var(--position) - 1)))
    translateY(-300px)
    rotate(calc(-360deg / var(--quantity) * (var(--position) - 1)));
  transition: all 0.3s ease;
}

.item.centered {
  transform: translate(-50%, -50%) rotate(0deg) translateY(0) rotate(0deg);
  z-index: 10;
}

/* Card Container Styles */
.card-container {
  position: relative;
  width: 100%;
  height: 100%;
  transition: 200ms;
}

.card-container:hover {
  width: 180px;
  height: 245px;
}

.original-image {
  position: absolute;
  inset: 0;
  z-index: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 20px;
  transition: opacity 0.3s ease;
  background: linear-gradient(45deg, #1a1a1a, #262626);
 
  overflow: hidden;
  box-shadow:
    0 0 20px rgba(0, 0, 0, 0.3),
    inset 0 0 20px rgba(0, 0, 0, 0.2);
}

.secondary-image {
  position: absolute;
  inset: 0;
  z-index: 1;
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 20px;
  opacity: 0;
  transition: opacity 0.3s ease;
  background: linear-gradient(45deg, #1a1a1a, #262626);
  
  overflow: hidden;
  box-shadow:
    0 0 20px rgba(0, 0, 0, 0.3),
    inset 0 0 20px rgba(0, 0, 0, 0.2);
}



.card-container img {
  position: absolute;
  inset: 0;
  z-index: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 20px;
  transition: 700ms;
  background: linear-gradient(45deg, #1a1a1a, #262626);
  overflow: hidden;
  box-shadow:
    0 0 20px rgba(0, 0, 0, 0.3),
    inset 0 0 20px rgba(0, 0, 0, 0.2);
}

.card-content {
  position: relative;
  width: 100%;
  height: 100%;
}

.title {
  opacity: 0;
  transition: 300ms ease-in-out;
  position: absolute;
  font-size: 28px;
  font-weight: 800;
  letter-spacing: 4px;
  text-align: center;
  width: 100%;
  padding-top: 20px;
  background: linear-gradient(45deg, #00ffaa, #00a2ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  filter: drop-shadow(0 0 15px rgba(0, 255, 170, 0.3));
}

.subtitle {
  position: absolute;
  bottom: 40px;
  width: 100%;
  text-align: center;
  font-size: 12px;
  letter-spacing: 2px;
  transform: translateY(30px);
  color: rgba(255, 255, 255, 0.6);
}

.highlight {
  color: #00ffaa;
  margin-left: 5px;
  background: linear-gradient(90deg, #5c67ff, #ad51ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: bold;
}

.glowing-elements {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.glow-1,
.glow-2,
.glow-3 {
  position: absolute;
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: radial-gradient(
    circle at center,
    rgba(25, 4, 4, 0.3) 0%,
    rgba(0, 255, 170, 0) 70%
  );
  filter: blur(15px);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.glow-1 { top: -20px; left: -20px; }
.glow-2 { top: 50%; right: -30px; transform: translateY(-50%); }
.glow-3 { bottom: -20px; left: 30%; }

.card-particles span {
  position: absolute;
  width: 3px;
  height: 3px;
  background: #100404;
  border-radius: 50%;
  opacity: 0;
  transition: opacity 0.3s ease;
}

/* Hover Effects */
.card-container:hover .original-image {
  opacity: 0;
}

.card-container:hover .secondary-image {
  opacity: 1;
}
.card-container:hover .glowing-elements div {
  opacity: 1;
}

.card-container:hover .card-particles span {
  animation: particleFloat 2s infinite;
}

/* Particle Positions */
.card-particles span:nth-child(1) { --x: 1; --y: -1; top: 40%; left: 20%; }
.card-particles span:nth-child(2) { --x: -1; --y: -1; top: 60%; right: 20%; }
.card-particles span:nth-child(3) { --x: 0.5; --y: 1; top: 20%; left: 40%; }
.card-particles span:nth-child(4) { --x: -0.5; --y: 1; top: 80%; right: 40%; }
.card-particles span:nth-child(5) { --x: 1; --y: 0.5; top: 30%; left: 60%; }
.card-particles span:nth-child(6) { --x: -1; --y: 0.5; top: 70%; right: 60%; }

/* Animation Keyframes */
@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes particleFloat {
  0% { transform: translate(0, 0); opacity: 0; }
  50% { opacity: 1; }
  100% { transform: translate(calc(var(--x, 0) * 30px), calc(var(--y, 0) * 30px)); opacity: 0; }
}

/* Existing styles for content */
.content {
  position: absolute;
  text-align: center;
  color: white;
}

.content h1 {
  font-size: 4rem;
  margin: 0;
}

.author h2 {
  margin: 0;
  font-size: 1.5rem;
}

.author p {
  margin: 5px 0;
}

/* Responsive styles */
@media (max-width: 768px) {
  .hero-title {
    font-size: 2.5rem;
  }

  .hero-image {
    width: 100%;
    opacity: 0.3;
  }

  .stats-grid {
    flex-direction: column;
    gap: 2rem;
  }

  .trending-grid {
    flex-direction: column;
  }

  .nft-grid {
    max-width: 100%;
  }

  .trending-title,
  .section-title {
    font-size: 2rem;
  }

  .subscribe-title {
    font-size: 2.5rem;
  }
  
}




